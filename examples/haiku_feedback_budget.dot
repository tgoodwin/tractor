digraph {
  graph [
    goal="Low-budget haiku loop that should halt on total cost before the full loop completes",
    status_agent=claude,
    max_total_cost_usd="0.01"
  ]

  start [shape=Mdiamond]

  ask_claude [
    shape=box,
    llm_provider=claude,
    llm_model="claude-opus-4-7",
    timeout="10m",
    retries=1,
    max_iterations=5,
    prompt="Plan and then write a one-line haiku about a tractor at dawn. Previous critique (if any): {{codex_review.last}}"
  ]

  codex_review [
    shape=box,
    llm_provider=codex,
    llm_model="gpt-5",
    max_iterations=5,
    prompt="Evaluate this haiku for imagery and meter:\n{{ask_claude.last}}\n\nReturn exactly one line beginning with 'VERDICT: accept' or 'VERDICT: reject'. If you reject, follow with a one-line critique under 80 characters."
  ]

  codex_gate [shape=diamond]

  ask_codex [
    shape=box,
    llm_provider=codex,
    llm_model="gpt-5",
    max_iterations=5,
    prompt="Write a one-line haiku that continues this thought: {{ask_claude.last}}. Previous critique (if any): {{gemini_review.last}}"
  ]

  gemini_review [
    shape=box,
    llm_provider=gemini,
    llm_model="gemini-3-pro",
    max_iterations=5,
    prompt="Evaluate this haiku for meter and continuity:\n{{ask_codex.last}}\n\nReturn exactly one line beginning with 'VERDICT: accept' or 'VERDICT: reject'. If you reject, follow with a one-line critique under 80 characters."
  ]

  gemini_gate [shape=diamond]

  ask_gemini [
    shape=box,
    llm_provider=gemini,
    llm_model="gemini-3-pro",
    prompt="Write a one-line haiku that calmly concludes this sequence: {{ask_codex.last}}"
  ]

  summarize [
    shape=box,
    llm_provider=claude,
    llm_model="claude-sonnet-4-6",
    prompt="Combine these three haikus into a short titled sequence.\n\n1. {{ask_claude.last}}\n2. {{ask_codex.last}}\n3. {{ask_gemini.last}}"
  ]

  exit [shape=Msquare]

  start -> ask_claude
  ask_claude -> codex_review
  codex_review -> codex_gate
  codex_gate -> ask_claude [condition="context.codex_review.last_output contains \"VERDICT: reject\""]
  codex_gate -> ask_codex  [condition="context.codex_review.last_output contains \"VERDICT: accept\""]
  ask_codex -> gemini_review
  gemini_review -> gemini_gate
  gemini_gate -> ask_codex  [condition="context.gemini_review.last_output contains \"VERDICT: reject\""]
  gemini_gate -> ask_gemini [condition="context.gemini_review.last_output contains \"VERDICT: accept\""]
  ask_gemini -> summarize
  summarize -> exit
}
