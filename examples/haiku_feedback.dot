digraph {
  graph [goal="Three-agent haiku with codergen-reviewed feedback loops and a composite summary", status_agent=claude]

  start [shape=Mdiamond]

  ask_claude [
    shape=box,
    llm_provider=claude,
    timeout="10m",
    retries=2,
    max_iterations=5,
    prompt="Plan then write a one-line haiku about a tractor starting work. First list your planning notes, then after a blank line output only the final haiku on one line. Previous critique (if any): {{codex_review.last}}"
  ]

  codex_review [
    shape=box,
    llm_provider=codex,
    max_iterations=5,
    prompt="Evaluate this haiku for imagery and meter:\n{{ask_claude.last}}\n\nReturn exactly one line beginning with 'VERDICT: accept' or 'VERDICT: reject'. If you reject, follow with a one-line critique under 80 characters on the next line."
  ]

  codex_gate [shape=diamond]

  ask_codex [
    shape=box,
    llm_provider=codex,
    max_iterations=5,
    prompt="Plan then write a one-line haiku that continues this thought: {{ask_claude.last}}. First list your planning notes, then after a blank line output only the final haiku. Previous critique (if any): {{gemini_review.last}}"
  ]

  gemini_review [
    shape=box,
    llm_provider=gemini,
    max_iterations=5,
    prompt="Evaluate this haiku for meter and continuity:\n{{ask_codex.last}}\n\nReturn exactly one line beginning with 'VERDICT: accept' or 'VERDICT: reject'. If you reject, follow with a one-line critique under 80 characters."
  ]

  gemini_gate [shape=diamond]

  ask_gemini [
    shape=box,
    llm_provider=gemini,
    prompt="Write a one-line haiku that calmly concludes this sequence: {{ask_codex.last}}"
  ]

  summarize [
    shape=box,
    llm_provider=claude,
    prompt="Combine these three haikus into one composite document. Output a short title on line one, then the three haikus in order on their own lines, then a one-sentence reflection on the sequence.\n\n1. {{ask_claude.last}}\n2. {{ask_codex.last}}\n3. {{ask_gemini.last}}"
  ]

  exit [shape=Msquare]

  start -> ask_claude
  ask_claude -> codex_review
  codex_review -> codex_gate
  codex_gate -> ask_claude [condition="context.codex_review.last_output contains \"VERDICT: reject\""]
  codex_gate -> ask_codex  [condition="context.codex_review.last_output contains \"VERDICT: accept\""]
  ask_codex -> gemini_review
  gemini_review -> gemini_gate
  gemini_gate -> ask_codex  [condition="context.gemini_review.last_output contains \"VERDICT: reject\""]
  gemini_gate -> ask_gemini [condition="context.gemini_review.last_output contains \"VERDICT: accept\""]
  ask_gemini -> summarize
  summarize -> exit
}
