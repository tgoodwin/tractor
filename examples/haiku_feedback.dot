digraph {
  graph [goal="Three-agent haiku with stub-judged feedback loops and a composite summary", status_agent=claude]

  start [shape=Mdiamond]

  ask_claude [
    shape=box,
    llm_provider=claude,
    timeout="10m",
    retries=2,
    max_iterations=5,
    prompt="Plan then write a one-line haiku about a tractor starting work. First list your planning notes, then after a blank line output only the final haiku on one line. Previous critique (if any): {{codex_review.last_critique}}"
  ]

  codex_review [
    shape=hexagon,
    type=judge,
    judge_mode=stub,
    reject_probability=0.5,
    accept_critique="imagery lands; move forward",
    reject_critique="imagery too literal; sharpen the turn on line one",
    max_iterations=5
  ]

  ask_codex [
    shape=box,
    llm_provider=codex,
    max_iterations=5,
    prompt="Plan then write a one-line haiku that continues this thought: {{ask_claude.last}}. First list your planning notes, then after a blank line output only the final haiku. Previous critique (if any): {{gemini_review.last_critique}}"
  ]

  gemini_review [
    shape=hexagon,
    type=judge,
    judge_mode=stub,
    reject_probability=0.5,
    accept_critique="meter and continuity check out",
    reject_critique="compute using python: score syllables per line and retry with a tighter middle",
    max_iterations=5
  ]

  ask_gemini [
    shape=box,
    llm_provider=gemini,
    prompt="Write a one-line haiku that calmly concludes this sequence: {{ask_codex.last}}"
  ]

  summarize [
    shape=box,
    llm_provider=claude,
    prompt="Combine these three haikus into one composite document. Output a short title on line one, then the three haikus in order on their own lines, then a one-sentence reflection on the sequence.\n\n1. {{ask_claude.last}}\n2. {{ask_codex.last}}\n3. {{ask_gemini.last}}"
  ]

  exit [shape=Msquare]

  start -> ask_claude
  ask_claude -> codex_review
  codex_review -> ask_claude [condition="reject"]
  codex_review -> ask_codex [condition="accept"]
  ask_codex -> gemini_review
  gemini_review -> ask_codex [condition="reject"]
  gemini_review -> ask_gemini [condition="accept"]
  ask_gemini -> summarize
  summarize -> exit
}
