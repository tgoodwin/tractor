digraph {
  graph [goal="Status feed wait probe", status_agent=claude]

  start [shape=Mdiamond]
  review_gate [shape=hexagon, wait_prompt="Approve the operator handoff?"]
  approved [shape=parallelogram, command=["sh","-c","printf approved"]]
  rejected [shape=parallelogram, command=["sh","-c","printf rejected"]]
  exit [shape=Msquare]

  start -> review_gate
  review_gate -> approved [label="approve"]
  review_gate -> rejected [label="reject"]
  approved -> exit
  rejected -> exit
}
